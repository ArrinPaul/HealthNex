# Required Server Variables
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long
GOOGLE_AI_API_KEY=your_gemini_api_key_here
CONVEX_DEPLOYMENT=your_convex_deployment_name

# Required Public Variables
NEXT_PUBLIC_CONVEX_URL=your_convex_url_here
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Weather API (optional, for weather-based health features)
NEXT_PUBLIC_WEATHER_PROVIDER=open-meteo
NEXT_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
NEXT_PUBLIC_ENABLE_VOICE_CHAT=true
NEXT_PUBLIC_ENABLE_REALTIME=true
NEXT_PUBLIC_ENABLE_DEBUG=false

# Initial Super Admin Credentials (set these in .env, never commit real values)
TEST_ADMIN_EMAIL=your_admin_email_here
TEST_ADMIN_PASSWORD=your_admin_password_here
